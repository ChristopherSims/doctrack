{
  "name": "doctrack",
  "version": "0.1.0",
  "description": "Document Requirements Tracker with Git-like Version Control",
  "main": "./dist/main/main.js",
  "homepage": "./",
  "preload": "./dist/main/preload.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:react\"",
    "dev:electron": "tsc -p tsconfig.main.json && electron .",
    "dev:react": "vite",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.main.json",
    "start": "electron .",
    "test": "vitest"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@mui/x-data-grid": "^6.20.4",
    "axios": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^2.0.0",
    "typescript": "^5.1.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
