{
  "name": "doctrack",
  "version": "0.1.0",
  "description": "Document Requirements Tracker with Git-like Version Control",
  "main": "./dist/main/main.js",
  "homepage": "./",
  "preload": "./dist/main/preload.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:react\"",
    "dev:electron": "tsc -p tsconfig.main.json && electron .",
    "dev:react": "vite",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.main.json",
    "start": "electron .",
    "test": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^2.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.1.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
